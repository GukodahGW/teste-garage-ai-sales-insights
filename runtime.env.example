# Configure estas variaveis no ambiente do sistema ou do servico.
GARAGE_DATABASE_URL=sqlite+pysqlite:///./garage.db
GARAGE_DATABASE_ECHO=false

# Provider LangChain OpenAI-compatible. Use API_KEY_FILE ou API_KEY, nunca ambos.
GARAGE_LLM_PROVIDER=gemma
GARAGE_LLM_BASE_URL=https://gemma.example.com/v1
GARAGE_LLM_MODEL=gemma-4-e4b-it
GARAGE_LLM_API_KEY_FILE=/path/to/gemma-api-key.txt
# GARAGE_LLM_API_KEY=replace-me
GARAGE_LLM_TIMEOUT_SECONDS=180
GARAGE_LLM_MAX_RETRIES=2
GARAGE_LLM_MAX_TOKENS=512
GARAGE_LLM_TEMPERATURE=0
GARAGE_LLM_ENABLE_THINKING=false
