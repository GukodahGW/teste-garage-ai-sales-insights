# Configure estas variaveis no ambiente do sistema ou do servico.
GARAGE_DATABASE_URL=sqlite+pysqlite:///./garage.db
GARAGE_DATABASE_ECHO=false

# API publica de jobs duraveis da Gemma. Use API_KEY_FILE ou API_KEY, nunca ambos.
GARAGE_LLM_PROVIDER=gemma
GARAGE_LLM_BASE_URL=https://gemma.lontra-agil.online/v1
GARAGE_LLM_MODEL=gemma-4-E4B-it-Q4_K_M.gguf
GARAGE_LLM_API_KEY_FILE=/path/to/cloudflare-api-key.txt
# GARAGE_LLM_API_KEY=replace-me
# Prazo total: submissao, espera na fila e inferencia.
GARAGE_LLM_TIMEOUT_SECONDS=900
GARAGE_LLM_MAX_RETRIES=2
GARAGE_LLM_MAX_TOKENS=512
GARAGE_LLM_TEMPERATURE=0
GARAGE_LLM_ENABLE_THINKING=false

# Numero maximo de novas composicoes quando o plano contem uma data de calendario invalida.
GARAGE_PLANNER_DATE_VALIDATION_MAX_RETRIES=2
# Numero maximo de novas composicoes quando filtros alteram ou inventam entidades.
GARAGE_PLANNER_FILTER_VALIDATION_MAX_RETRIES=2
